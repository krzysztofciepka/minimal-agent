{
  "name": "minimal-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Lightweight CLI coding agent with OpenAI-compatible API",
  "main": "src/cli.ts",
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bun run src/cli.ts",
    "tui": "bun run src/cli.ts --tui",
    "typecheck": "tsc --noEmit",
    "build": "bun run scripts/build.ts",
    "build:all": "bun run scripts/build.ts --all",
    "test": "bun test"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "0.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "auto-bind": "5.0.1",
    "bidi-js": "^1.0.3",
    "chalk": "5.6.2",
    "cli-boxes": "3.0.0",
    "code-excerpt": "4.0.0",
    "emoji-regex": "^10.6.0",
    "figures": "^6.1.0",
    "get-east-asian-width": "1.5.0",
    "indent-string": "5.0.0",
    "lodash-es": "^4.18.1",
    "react": "19.2.4",
    "react-compiler-runtime": "^1.0.0",
    "react-reconciler": "0.33.0",
    "semver": "^7.7.4",
    "signal-exit": "^4.1.0",
    "stack-utils": "2.0.6",
    "strip-ansi": "7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "type-fest": "^5.5.0",
    "usehooks-ts": "^3.1.1",
    "wrap-ansi": "9.0.2",
    "ws": "8.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "typescript": "^5.3.0"
  }
}